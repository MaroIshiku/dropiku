# Public HTTPS URL used when Dropiku creates capability links.
APP_BASE_URL=https://drop.example.invalid

# Prefer APP_SETUP_SECRET_FILE in production. Minimum 32 characters.
APP_SETUP_SECRET=replace-with-at-least-32-random-characters
# APP_SETUP_SECRET_FILE=/run/secrets/dropiku_setup_secret

# Exactly 32 random bytes encoded as Base64. Prefer APP_MASTER_KEY_FILE.
APP_MASTER_KEY=replace-with-a-base64-encoded-32-byte-key
# APP_MASTER_KEY_FILE=/run/secrets/dropiku_master_key

TZ=Europe/Berlin
PORT=8080
HOST=0.0.0.0
DATA_DIR=./data
TRUSTED_PROXIES=false
MAX_STORAGE_BYTES=107374182400
DEFAULT_MAX_FILE_BYTES=5368709120
ABSOLUTE_MAX_FILE_BYTES=21474836480
MAX_CONCURRENT_UPLOADS=3
MAX_CONCURRENT_DOWNLOADS=6
LOG_LEVEL=info
# CLAMAV_HOST=clamav
CLAMAV_PORT=3310
